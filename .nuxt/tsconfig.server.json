{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "allowSyntheticDefaultImports": true,
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "paths": {
      "#imports": [
        "./types/nitro-imports"
      ],
      "~/*": [
        "../*"
      ],
      "@/*": [
        "../*"
      ],
      "~~/*": [
        "../*"
      ],
      "@@/*": [
        "../*"
      ],
      "@unhead/vue": [
        "../node_modules/@unhead/vue"
      ],
      "@nuxt/devtools": [
        "../node_modules/@nuxt/devtools"
      ],
      "vue": [
        "../node_modules/vue"
      ],
      "@vue/runtime-core": [
        "../node_modules/@vue/runtime-core"
      ],
      "@vue/compiler-sfc": [
        "../node_modules/@vue/compiler-sfc"
      ],
      "@nuxt/schema": [
        "../node_modules/@nuxt/schema"
      ],
      "nuxt": [
        "../node_modules/nuxt"
      ],
      "@nuxtjs/robots": [
        "../node_modules/@nuxtjs/robots"
      ],
      "@nuxtjs/sitemap": [
        "../node_modules/@nuxtjs/sitemap"
      ],
      "nuxt-link-checker": [
        "../node_modules/nuxt-link-checker"
      ],
      "nuxt-schema-org": [
        "../node_modules/nuxt-schema-org"
      ],
      "nuxt-seo-utils": [
        "../node_modules/nuxt-seo-utils"
      ],
      "nuxt-site-config": [
        "../node_modules/nuxt-site-config"
      ],
      "nitropack": [
        "../node_modules/nitropack"
      ],
      "defu": [
        "../node_modules/defu"
      ],
      "h3": [
        "../node_modules/h3"
      ],
      "consola": [
        "../node_modules/consola"
      ],
      "ofetch": [
        "../node_modules/ofetch"
      ],
      "crossws": [
        "../node_modules/crossws"
      ],
      "vite/client": [
        "../node_modules/vite/client"
      ],
      "nitropack/types": [
        "../node_modules/nitropack/types"
      ],
      "nitropack/runtime": [
        "../node_modules/nitropack/runtime"
      ],
      "#shared": [
        "../shared"
      ],
      "#shared/*": [
        "../shared/*"
      ],
      "#server": [
        "../server"
      ],
      "#server/*": [
        "../server/*"
      ],
      "#build": [
        "./"
      ],
      "#build/*": [
        "./*"
      ],
      "#internal/nuxt/paths": [
        "../node_modules/@nuxt/nitro-server/dist/runtime/utils/paths"
      ],
      "#unhead/composables": [
        "../node_modules/nuxt/dist/head/runtime/composables"
      ],
      "#site-config": [
        "../node_modules/nuxt-site-config/dist/runtime"
      ],
      "#site-config/*": [
        "../node_modules/nuxt-site-config/dist/runtime/*"
      ],
      "#robots": [
        "../node_modules/@nuxtjs/robots/dist/runtime"
      ],
      "#robots/*": [
        "../node_modules/@nuxtjs/robots/dist/runtime/*"
      ],
      "#sitemap": [
        "../node_modules/@nuxtjs/sitemap/dist/runtime"
      ],
      "#sitemap/*": [
        "../node_modules/@nuxtjs/sitemap/dist/runtime/*"
      ],
      "#link-checker": [
        "../node_modules/nuxt-link-checker/dist/runtime"
      ],
      "#link-checker/*": [
        "../node_modules/nuxt-link-checker/dist/runtime/*"
      ],
      "#og-image": [
        "../node_modules/nuxt-og-image/dist/runtime"
      ],
      "#og-image/*": [
        "../node_modules/nuxt-og-image/dist/runtime/*"
      ],
      "#og-image-cache": [
        "../node_modules/nuxt-og-image/dist/runtime/server/og-image/cache/lru"
      ],
      "#og-image/emoji-transform": [
        "../node_modules/nuxt-og-image/dist/runtime/server/og-image/core/transforms/emojis/fetch"
      ],
      "@unhead/schema-org/vue": [
        "../node_modules/nuxt-schema-org/dist/vendor/schema-org-v2/vue"
      ],
      "@unhead/schema-org": [
        "../node_modules/nuxt-schema-org/dist/vendor/schema-org-v2/index"
      ],
      "#schema-org": [
        "../node_modules/nuxt-schema-org/dist/runtime"
      ],
      "#schema-org/*": [
        "../node_modules/nuxt-schema-org/dist/runtime/*"
      ],
      "#seo-utils": [
        "../node_modules/nuxt-seo-utils/dist/runtime"
      ],
      "#seo-utils/*": [
        "../node_modules/nuxt-seo-utils/dist/runtime/*"
      ],
      "#internal/nuxt-simple-robots": [
        "../node_modules/@nuxtjs/robots/dist/runtime/server/composables"
      ],
      "#internal/nuxt-simple-robots/*": [
        "../node_modules/@nuxtjs/robots/dist/runtime/server/composables/*"
      ],
      "#internal/nuxt-robots": [
        "../node_modules/@nuxtjs/robots/dist/runtime/server/composables"
      ],
      "#internal/nuxt-robots/*": [
        "../node_modules/@nuxtjs/robots/dist/runtime/server/composables/*"
      ],
      "#link-checker/content-provider": [
        "../node_modules/nuxt-link-checker/dist/runtime/server/providers/noop"
      ]
    },
    "lib": [
      "esnext",
      "webworker",
      "dom.iterable"
    ],
    "noUncheckedIndexedAccess": true,
    "allowArbitraryExtensions": true
  },
  "include": [
    "./types/nitro-nuxt.d.ts",
    "../node_modules/runtime/server",
    "../node_modules/dist/runtime/server",
    "../node_modules/nuxt-site-config/dist/runtime/server",
    "../node_modules/nuxt-site-config/dist/dist/runtime/server",
    "../server/**/*",
    "../shared/**/*.d.ts",
    "./types/nitro.d.ts"
  ],
  "exclude": [
    "../node_modules",
    "../node_modules/nuxt/node_modules",
    "../node_modules/@nuxtjs/seo/node_modules",
    "../node_modules/@nuxt/devtools/node_modules",
    "../node_modules/@nuxt/telemetry/node_modules",
    "../node_modules/nuxt-site-config/node_modules",
    "../node_modules/@nuxtjs/robots/node_modules",
    "../node_modules/@nuxtjs/sitemap/node_modules",
    "../node_modules/nuxt-link-checker/node_modules",
    "../node_modules/nuxt-og-image/node_modules",
    "../node_modules/nuxt-schema-org/node_modules",
    "../node_modules/nuxt-seo-utils/node_modules",
    "../dist"
  ]
}